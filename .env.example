# App Engine production scaffold
#
# Copy this file to .env.local when wiring real services.

DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/app_engine?sslmode=require"

# Separate Neon database or branch where generated apps receive schema/seed data.
GENERATED_APP_DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/generated_app?sslmode=require"

# When true, project creation/listing uses .app-engine/dev-projects.json.
# Set to false after DATABASE_URL points to a real Neon database.
APP_ENGINE_LOCAL_MODE="true"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# Optional OAuth providers for admin/customer sign-in.
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Owner bootstrap. First matching email becomes owner/admin.
APP_ENGINE_OWNER_EMAIL="you@example.com"

# Worker adapters. OpenAI is preferred when both are present.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.1"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"
GITHUB_TOKEN=""
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""
