# App Engine local development scaffold
#
# Copy this file to .env.local for local development.
# For Vercel, use .env.vercel.example as the allow-list instead of uploading .env.local.

# DATABASE_URL is preferred. The app also accepts POSTGRES_URL,
# POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING, and NEON_DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/app_engine?sslmode=require"

# Automatic generated-app database provisioning.
# The engine uses these to create/reuse a Neon branch for each generated app.
NEON_API_KEY=""
NEON_PROJECT_ID=""
NEON_PARENT_BRANCH_ID=""
NEON_DATABASE_NAME="neondb"
NEON_ROLE_NAME="neondb_owner"
NEON_GENERATED_APP_BRANCH_PREFIX="app-engine-generated"
NEON_USE_POOLED_CONNECTION="false"

# Optional manual per-app fallback. Prefer one database/branch per generated app.
# After a project is created, the cockpit shows exact keys like:
# GENERATED_APP_DATABASE_URL_CHURCH_CONNECT="postgresql://..."
# GENERATED_APP_DATABASE_URL_LOCAL_ABC123="postgresql://..."
#
# Only use the global fallback below when intentionally sharing one generated-app
# database for temporary testing.
APP_ENGINE_ALLOW_GLOBAL_GENERATED_DATABASE_URL="false"
GENERATED_APP_DATABASE_URL=""
APP_ENGINE_GENERATED_APP_DATABASE_URL=""

# When true, project creation/listing uses .app-engine/dev-projects.json.
# Set to false after a Postgres URL points to a real Neon database.
# Never use true in Vercel because Vercel cannot persist .app-engine/dev-projects.json.
APP_ENGINE_LOCAL_MODE="true"

# Local admin convenience. Production deployments must use OAuth sign-in.
APP_ENGINE_DEV_ADMIN_BYPASS="true"
APP_ENGINE_SETUP_ADMIN_BYPASS="false"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# Sign-in providers (each is dormant until its keys are set).
# Google is the easiest consumer option; GitHub is the operator/secondary option.
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Passwordless email magic-link (most turnkey for non-technical users). Needs a
# Resend API key + a verified "from" address, AND a database (stores the
# verification token). Activates only when all of these are present.
AUTH_RESEND_KEY=""
EMAIL_FROM="We Succeed <signin@we-succeed.org>"

# Owner bootstrap. First matching email becomes owner/admin.
APP_ENGINE_OWNER_EMAIL="you@example.com"

# Staged go-public control (Step 6). Decides who reaches the consumer surface
# (two-door entry + problem/opportunity intakes + their POST submit APIs).
# Operator screens stay owner/admin-only in every mode.
#   owner     - DEFAULT. Closed to non-owners; identical to pre-go-public behavior.
#   allowlist - Controlled real users: only approved customer emails get in.
#   public    - Open: any signed-in customer reaches the consumer surface.
# Unknown/blank values fail closed to "owner". Going public also requires the
# Vercel/provider spend cap to be set on the account (owner action, not code).
APP_ENGINE_PUBLIC_ACCESS="owner"

# Comma/space/semicolon-separated emails approved for the "allowlist" rung above.
# Ignored in "owner" and "public" modes.
APP_ENGINE_CUSTOMER_ALLOWLIST=""

# Worker adapters. OpenAI is preferred when both are present.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.1"

# LLM cost metering + spend guard.
# Token counts are recorded exactly; these rates only convert tokens -> $ (set the
# real numbers for your model). Per-run cap bounds paid calls per build (then it
# degrades to free deterministic output).
APP_ENGINE_LLM_USD_PER_1K_INPUT="0.0015"
APP_ENGINE_LLM_USD_PER_1K_OUTPUT="0.006"
APP_ENGINE_LLM_MAX_CALLS_PER_RUN="24"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"
GITHUB_TOKEN=""
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""
