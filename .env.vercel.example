# App Engine Vercel environment template
#
# Use this as the allow-list for Vercel Production and Preview variables.
# Do not upload .env.local wholesale; it may contain localhost URLs or unused provider snippets.

# Core persistence. Must point to the Neon database that has run npm run db:setup.
# DATABASE_URL is preferred, but the app also reads Neon/Vercel integration aliases:
# POSTGRES_URL, POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING, and NEON_DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
APP_ENGINE_LOCAL_MODE="false"

# Production access. Do not enable local/dev bypasses on Vercel.
APP_ENGINE_DEV_ADMIN_BYPASS="false"
APP_ENGINE_SETUP_ADMIN_BYPASS="false"
AUTH_SECRET="replace-with-base64-or-long-random-secret"
AUTH_URL="https://YOUR-APP.vercel.app"
APP_ENGINE_OWNER_EMAIL="you@example.com"

# OAuth provider for Auth.js sign-in. Configure at least one provider.
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Neon Platform API for generated app database branches.
NEON_API_KEY=""
NEON_PROJECT_ID=""
NEON_PARENT_BRANCH_ID=""
NEON_DATABASE_NAME="neondb"
NEON_ROLE_NAME="neondb_owner"
NEON_GENERATED_APP_BRANCH_PREFIX="app-engine-generated"
NEON_USE_POOLED_CONNECTION="true"

# Worker provider. OpenAI is optional because the engine can fall back to local deterministic workers.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.1"
APP_ENGINE_WORKER_TIMEOUT_MS="12000"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"

# Vercel deployment automation.
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""

# Optional only. Do not set global generated app database fallbacks in Vercel unless you intentionally want sharing.
APP_ENGINE_ALLOW_GLOBAL_GENERATED_DATABASE_URL="false"
