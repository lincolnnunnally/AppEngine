# AppEngine shared ecosystem env example.
# Copy this to a private path outside git, for example:
# ~/Documents/Codex/private-env/appengine.shared.env

# Consolidated Life Produces Life Supabase
SUPABASE_PROJECT_REF=
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
VITE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared provider/API credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_TEAM_ID=
RENDER_API_KEY=
GITHUB_TOKEN=
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=

# Shared email/SMS defaults
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
