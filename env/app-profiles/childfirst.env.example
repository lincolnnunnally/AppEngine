# ChildFirst Solutions app env profile (AppEngine-directed).
# Shared secrets live in:
#   ~/Documents/Codex/private-env/appengine.shared.env
# This profile selects which shared keys this app needs + app defaults.

APPENGINE_SHARED_ENV_KEYS=SUPABASE_URL,NEXT_PUBLIC_SUPABASE_URL,SUPABASE_ANON_KEY,NEXT_PUBLIC_SUPABASE_ANON_KEY,SUPABASE_SERVICE_ROLE_KEY,OPENAI_API_KEY,SMTP_HOST,SMTP_PORT,SMTP_USER,SMTP_PASSWORD,SMTP_FROM,JWT_SECRET,ENCRYPTION_KEY,APP_ENGINE_OWNER_EMAIL
APPENGINE_REQUIRED_ENV_KEYS=NEXT_PUBLIC_SUPABASE_URL,NEXT_PUBLIC_SUPABASE_ANON_KEY

# LPL unified Supabase (not Neon)
CHILDFIRST_SUPABASE_TARGET=life_produces_life
CHILDFIRST_TABLE_PREFIX=childfirst_
NEXT_PUBLIC_APP_NAME=ChildFirst Solutions
NEXT_PUBLIC_APP_MODE=co_parenting_life_first

# Public surface
NEXT_PUBLIC_SITE_URL=https://childfirst.unitedundergod.org
FRONTEND_URL=https://childfirst.unitedundergod.org

# Product defaults
CHILDFIRST_DEFAULT_FAMILY_GOAL=Build a calm, connected childhood across both homes.
CHILDFIRST_ENABLE_PROFESSIONAL_LAYER=true
CHILDFIRST_ENABLE_COURT_LAYER=true
