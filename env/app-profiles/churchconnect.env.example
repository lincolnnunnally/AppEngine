# ChurchConnect app env profile.
# This file selects shared keys and adds app-specific defaults.

APPENGINE_SHARED_ENV_KEYS=SUPABASE_URL,VITE_SUPABASE_URL,SUPABASE_ANON_KEY,VITE_SUPABASE_ANON_KEY,SUPABASE_SERVICE_ROLE_KEY,OPENAI_API_KEY,STRIPE_SECRET_KEY,STRIPE_PUBLISHABLE_KEY,VITE_STRIPE_PUBLISHABLE_KEY,STRIPE_WEBHOOK_SECRET,SMTP_HOST,SMTP_PORT,SMTP_USER,SMTP_PASSWORD,SMTP_FROM,TWILIO_ACCOUNT_SID,TWILIO_AUTH_TOKEN,TWILIO_PHONE_NUMBER,SPACESHIP_API_KEY,SPACESHIP_API_SECRET,JWT_SECRET,ENCRYPTION_KEY,APP_ENGINE_OWNER_EMAIL
APPENGINE_REQUIRED_ENV_KEYS=SUPABASE_URL,SUPABASE_SERVICE_ROLE_KEY,MONGO_URL,DB_NAME,JWT_SECRET,ENCRYPTION_KEY,CC_TEST_EMAIL,CC_TEST_PASSWORD

VITE_API_URL=https://api.churchconnect.cloud
REACT_APP_BACKEND_URL=https://api.churchconnect.cloud
FRONTEND_URL=https://churchconnect.cloud
VITE_CHURCHCONNECT_CHURCH_SLUG=milstead-church

CHURCHCONNECT_SUPABASE_TARGET=life_produces_life
CHURCHCONNECT_ALLOWED_CHURCH_SLUGS=milstead-church
CHURCHCONNECT_PROOF_CHURCH_SLUG=milstead-church
CHURCHCONNECT_DEFAULT_CHURCH_NAME=Milstead Baptist Church

CC_TEST_EMAIL=Lincoln@milstead.church
CC_TEST_PASSWORD=
CC_TEST_STAFF_NAME=Lincoln
CC_TEST_CHURCH_NAME=Milstead Baptist Church

MONGO_URL=
DB_NAME=churchconnect
SUPER_ADMIN_EMAIL=${APP_ENGINE_OWNER_EMAIL}
SUPER_ADMIN_DEFAULT_PASSWORD=
SEED_DEMO_USERS=false
CORS_ALLOWED_ORIGINS=https://churchconnect.cloud,https://www.churchconnect.cloud
